               </children>
            </HBox>
            <Label fx:id="restartRequiredLabel" text="%settings.database.restartRequired" visible="false" managed="false" style="-fx-text-fill: #e67e22;" />
         </children>
      </VBox>
   </children>
</AnchorPane>
