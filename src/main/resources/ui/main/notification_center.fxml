<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="notificationPanel"
      prefWidth="380.0"
      styleClass="notification-panel"
      xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.moinex.ui.main.NotificationCenterController">

   <children>
      <HBox alignment="CENTER_LEFT" styleClass="notification-panel-header" spacing="8.0">
         <children>
            <Label text="%main.notifications" styleClass="notification-panel-title">
               <font>
                  <Font name="System Bold" size="14.0"/>
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <JFXButton fx:id="markAllReadButton"
                       onAction="#handleMarkAllRead"
                       text="%notification.center.markAllRead"
                       styleClass="notification-action-btn">
               <font><Font size="10.0"/></font>
            </JFXButton>
            <JFXButton fx:id="clearAllButton"
                       onAction="#handleClearAll"
                       text="%notification.center.clearAll"
                       styleClass="notification-action-btn">
               <font><Font size="10.0"/></font>
               <HBox.margin><Insets right="4.0"/></HBox.margin>
            </JFXButton>
         </children>
         <padding><Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/></padding>
      </HBox>

      <ListView fx:id="notificationList" VBox.vgrow="ALWAYS" styleClass="notification-list"/>

      <Label fx:id="emptyLabel"
             text="%notification.center.empty"
             styleClass="notification-empty-label"
             maxWidth="Infinity"
             alignment="CENTER"
             managed="false"
             visible="false"
             VBox.vgrow="ALWAYS">
         <font><Font size="13.0"/></font>
      </Label>
   </children>
</VBox>
